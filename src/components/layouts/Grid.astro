---
interface Props {
  columns?: '2' | '3' | '4';
  gap?: 'sm' | 'md' | 'lg' | 'xl';
  class?: string;
}

const { columns = '2', gap = 'lg', class: className } = Astro.props;
---

<div class:list={['grid', `grid--${columns}`, `grid--gap-${gap}`, className]}>
  <slot />
</div>

<style>
  .grid {
    display: grid;
  }

  .grid--2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .grid--3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .grid--4 {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .grid--gap-sm {
    gap: var(--space-sm);
  }

  .grid--gap-md {
    gap: var(--space-md);
  }

  .grid--gap-lg {
    gap: var(--space-lg);
  }

  .grid--gap-xl {
    gap: var(--space-xl);
  }

  @media (max-width: 64rem) {
    .grid--4 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 48rem) {
    .grid--2,
    .grid--3,
    .grid--4 {
      grid-template-columns: 1fr;
    }
  }
</style>
