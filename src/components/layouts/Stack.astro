---
interface Props {
  gap?: 'xs' | 'sm' | 'md' | 'lg' | 'xl';
  align?: 'start' | 'center' | 'stretch';
  class?: string;
}

const { gap = 'md', align = 'start', class: className } = Astro.props;
---

<div class:list={['stack', `stack--${gap}`, `stack--align-${align}`, className]}>
  <slot />
</div>

<style>
  .stack {
    display: flex;
    flex-direction: column;
  }

  .stack--xs {
    gap: var(--space-xs);
  }

  .stack--sm {
    gap: var(--space-sm);
  }

  .stack--md {
    gap: var(--space-md);
  }

  .stack--lg {
    gap: var(--space-lg);
  }

  .stack--xl {
    gap: var(--space-xl);
  }

  .stack--align-start {
    align-items: flex-start;
  }

  .stack--align-center {
    align-items: center;
  }

  .stack--align-stretch {
    align-items: stretch;
  }
</style>
