---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/layouts/Section.astro';
import Stack from '../components/layouts/Stack.astro';
import Grid from '../components/layouts/Grid.astro';
import TwoCol from '../components/layouts/TwoCol.astro';
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Headline from '../components/ui/Headline.astro';
import Text from '../components/ui/Text.astro';

const stats = [
  { value: '5+', label: 'Years designing and building web experiences' },
  { value: '30+', label: 'Projects launched across marketing and product teams' },
  { value: '100%', label: 'Focus on responsive, accessible delivery' },
  { value: 'INF', label: 'Curiosity for refining systems and craft' },
];

const skillCategories = [
  {
    title: 'Design',
    glyph: 'DS',
    skills: ['UI/UX Design', 'Figma', 'Adobe Creative Suite', 'Responsive Design', 'Design Systems', 'Prototyping'],
  },
  {
    title: 'Frontend',
    glyph: 'FE',
    skills: ['HTML/CSS', 'JavaScript', 'TypeScript', 'React', 'Astro', 'Tailwind CSS'],
  },
  {
    title: 'Backend',
    glyph: 'BE',
    skills: ['Node.js', 'REST APIs', 'Databases', 'CMS Platforms', 'Authentication', 'Cloud Hosting'],
  },
  {
    title: 'Workflow',
    glyph: 'OP',
    skills: ['Git & GitHub', 'CI/CD', 'Performance Optimization', 'SEO', 'Accessibility (a11y)', 'Testing'],
  },
];

const experiences = [
  {
    role: 'Senior Web Designer & Developer',
    company: 'Freelance / Contract',
    period: '2022 - Present',
    description: 'Leading end-to-end design and development of modern websites for clients across various industries. Specializing in custom design systems, performance optimization, and accessible interfaces.',
    highlights: ['Custom design systems', 'Performance optimization', 'Client collaboration'],
  },
  {
    role: 'Web Developer',
    company: 'Agency / Studio',
    period: '2020 - 2022',
    description: 'Designed and developed responsive websites and web applications. Collaborated with cross-functional teams to deliver pixel-perfect implementations on tight deadlines.',
    highlights: ['Responsive development', 'Cross-team collaboration', 'Pixel-perfect builds'],
  },
  {
    role: 'Junior Developer',
    company: 'Startup',
    period: '2019 - 2020',
    description: 'Built and maintained front-end features, developed component libraries, and contributed to improving UI/UX across the product suite.',
    highlights: ['Component libraries', 'UI/UX improvement', 'Front-end features'],
  },
];

const projects = [
  {
    title: 'E-Commerce Redesign',
    description: 'Complete redesign and front-end rebuild of a modern e-commerce platform, focusing on conversion optimization and mobile-first design.',
    tags: ['UI/UX', 'React', 'E-Commerce'],
    link: '#',
  },
  {
    title: 'SaaS Dashboard',
    description: 'Designed and developed an intuitive analytics dashboard with real-time data visualization and a clean, minimal interface.',
    tags: ['Dashboard', 'TypeScript', 'Data Viz'],
    link: '#',
  },
  {
    title: 'Brand Identity Website',
    description: 'Built a high-impact marketing website with custom animations, scroll-driven storytelling, and optimized performance scores.',
    tags: ['Branding', 'Animation', 'Performance'],
    link: '#',
  },
  {
    title: 'Portfolio Template',
    description: 'An open-source, accessible portfolio template built with Astro and modern CSS, designed for creatives and developers.',
    tags: ['Open Source', 'Astro', 'Accessibility'],
    link: '#',
  },
];
---

<BaseLayout>
  <Header />
  <main id="main">
    <Section id="hero" inset="xl" class="hero">
      <TwoCol ratio="content" align="center">
        <Stack gap="lg" class="hero__content">
          <Badge class="reveal">Available for freelance and in-house roles</Badge>
          <Stack gap="sm">
            <Text size="sm" tone="soft" class="hero__eyebrow reveal">Hello, I'm Brandon</Text>
            <Headline as="h1" size="xl" class="hero__headline reveal">
              Designing websites that feel sharp, fast, and built on purpose.
            </Headline>
          </Stack>
          <Text size="lg" tone="soft" class="reveal">
            Website designer and developer focused on brand-first interfaces, modern front-end systems,
            and accessible experiences that hold up in production.
          </Text>
          <div class="hero__meta reveal">
            <span>Phoenix, Arizona</span>
            <span>Astro, React, design systems</span>
          </div>
          <div class="hero__actions reveal">
            <Button href="#projects">View selected work</Button>
            <Button href="#contact" variant="secondary">Start a conversation</Button>
          </div>
        </Stack>

        <div class="hero__visual reveal-scale">
          <div class="hero__orb hero__orb--primary"></div>
          <div class="hero__orb hero__orb--secondary"></div>
          <Card class="hero__panel" variant="strong">
            <div class="hero__panel-bar">
              <span></span>
              <span></span>
              <span></span>
            </div>
            <pre class="hero__code"><code><span class="hero__token-keyword">const</span> <span class="hero__token-name">brandon</span> = {`{`}
  <span class="hero__token-key">role</span>: <span class="hero__token-string">"Designer &amp; Developer"</span>,
  <span class="hero__token-key">specialty</span>: <span class="hero__token-string">"Forge-style systems"</span>,
  <span class="hero__token-key">focus</span>: [<span class="hero__token-string">"UI"</span>, <span class="hero__token-string">"Performance"</span>, <span class="hero__token-string">"Accessibility"</span>]
{`}`}</code></pre>
          </Card>
          <div class="hero__note recipe-surface">
            <p class="hero__note-label">Current focus</p>
            <p class="hero__note-value">Turning bespoke sections into reusable systems</p>
          </div>
        </div>
      </TwoCol>

      <div class="hero__scroll" aria-hidden="true">
        <span></span>
      </div>
    </Section>

    <Section id="about" inset="lg">
      <TwoCol ratio="content" gap="xl" align="start">
        <Stack gap="md">
          <Badge class="reveal">About</Badge>
          <Headline as="h2" size="lg" class="reveal">
            Design thinking with a developer's instinct for systems.
          </Headline>
          <Text size="lg" tone="soft" class="reveal">
            I like websites that feel considered end to end: clear story, strong pacing, practical
            interactions, and implementation details that are just as intentional as the visuals.
          </Text>
        </Stack>

        <Stack gap="md">
          <Text class="reveal">
            My process blends interface design, front-end architecture, and brand sensitivity so the
            final result is not just polished in screenshots, but dependable in code.
          </Text>
          <Text class="reveal">
            I care a lot about turning one-off design decisions into reusable patterns. That means
            stronger systems, cleaner handoff, and a site that stays coherent as it grows.
          </Text>
          <Text class="reveal">
            The work I enjoy most lives at the intersection of visual craft, component thinking, and
            performance-aware development.
          </Text>
        </Stack>
      </TwoCol>

      <Grid columns="4" gap="md" class="about__stats stagger">
        {stats.map((stat) => (
          <Card class="about__card reveal">
            <span class="about__value">{stat.value}</span>
            <p class="about__label">{stat.label}</p>
          </Card>
        ))}
      </Grid>
    </Section>

    <Section id="skills" inset="lg" surface="muted">
      <Stack gap="lg">
        <Stack gap="sm">
          <Badge class="reveal">Skills and tools</Badge>
          <Headline as="h2" size="lg" class="reveal">
            A practical toolkit for brand sites and front-end systems.
          </Headline>
          <Text size="lg" tone="soft" class="reveal">
            The stack changes by project, but the through-line is the same: clear structure, polished
            execution, and systems that are easy to extend.
          </Text>
        </Stack>

        <Grid columns="4" gap="md" class="stagger">
          {skillCategories.map((category) => (
            <Card class="skill-card reveal">
              <div class="skill-card__glyph">{category.glyph}</div>
              <h3 class="skill-card__title">{category.title}</h3>
              <ul class="skill-card__list">
                {category.skills.map((skill) => (
                  <li class="skill-card__item">{skill}</li>
                ))}
              </ul>
            </Card>
          ))}
        </Grid>
      </Stack>
    </Section>

    <Section id="experience" inset="lg">
      <Stack gap="lg">
        <Stack gap="sm">
          <Badge class="reveal">Experience</Badge>
          <Headline as="h2" size="lg" class="reveal">
            A track record built around design, delivery, and polish.
          </Headline>
          <Text size="lg" tone="soft" class="reveal">
            I’ve worked across freelance, agency, and startup environments, usually at the point where
            design quality and front-end execution need to meet cleanly.
          </Text>
        </Stack>

        <div class="experience__timeline">
          {experiences.map((exp, index) => (
            <article class="timeline-item reveal">
              <div class="timeline-item__rail" aria-hidden="true">
                <span class="timeline-item__dot"></span>
                {index < experiences.length - 1 && <span class="timeline-item__line"></span>}
              </div>

              <Card class="timeline-item__card">
                <p class="timeline-item__period">{exp.period}</p>
                <h3 class="timeline-item__role">{exp.role}</h3>
                <p class="timeline-item__company">{exp.company}</p>
                <p class="timeline-item__description">{exp.description}</p>
                <div class="timeline-item__highlights">
                  {exp.highlights.map((highlight) => (
                    <span class="highlight-tag">{highlight}</span>
                  ))}
                </div>
              </Card>
            </article>
          ))}
        </div>
      </Stack>
    </Section>

    <Section id="projects" inset="lg" surface="muted">
      <Stack gap="lg">
        <Stack gap="sm">
          <Badge class="reveal">Selected work</Badge>
          <Headline as="h2" size="lg" class="reveal">
            Projects where visual clarity and implementation quality mattered equally.
          </Headline>
          <Text size="lg" tone="soft" class="reveal">
            A mix of commerce, SaaS, marketing, and open-source work that reflects how I think about
            interaction, structure, and production-ready front-end delivery.
          </Text>
        </Stack>

        <Grid columns="2" gap="lg" class="stagger">
          {projects.map((project, index) => (
            <Card as="a" href={project.link} class="project-card reveal" aria-label={`View project: ${project.title}`}>
              <div class="project-card__preview">
                <div class="project-card__glow"></div>
                <div class="project-card__preview-inner">
                  <span class="project-card__index">0{index + 1}</span>
                  <span class="project-card__preview-label">Case study preview</span>
                </div>
              </div>
              <div class="project-card__body">
                <h3 class="project-card__title">{project.title}</h3>
                <p class="project-card__description">{project.description}</p>
                <div class="project-card__tags">
                  {project.tags.map((tag) => (
                    <span class="project-tag">{tag}</span>
                  ))}
                </div>
                <Button variant="ghost" class="project-card__action">View project</Button>
              </div>
            </Card>
          ))}
        </Grid>
      </Stack>
    </Section>

    <Section id="contact" inset="lg">
      <TwoCol ratio="content" align="start">
        <Stack gap="md">
          <Badge class="reveal">Contact</Badge>
          <Headline as="h2" size="lg" class="reveal">
            If you need a sharper web presence, let's build it well.
          </Headline>
          <Text size="lg" tone="soft" class="reveal">
            I’m open to freelance work, creative collaborations, and in-house opportunities where
            thoughtful design and reliable front-end execution both matter.
          </Text>

          <Card class="contact__info reveal">
            <h3 class="contact__info-title">Best ways to reach me</h3>
            <div class="contact__links">
              <a href="mailto:hello@brandonfuller.dev" class="contact-link">hello@brandonfuller.dev</a>
              <a href="https://github.com/brandonfuller" target="_blank" rel="noopener noreferrer" class="contact-link">GitHub</a>
              <a href="https://linkedin.com/in/brandonfuller" target="_blank" rel="noopener noreferrer" class="contact-link">LinkedIn</a>
            </div>
          </Card>
        </Stack>

        <Card class="contact__form-card reveal">
          <form class="contact__form" id="contact-form" action="#" method="POST">
            <div class="form-group">
              <label for="name" class="form-label">Name</label>
              <input type="text" id="name" name="name" class="form-input" placeholder="Your name" required autocomplete="name" />
            </div>

            <div class="form-group">
              <label for="email" class="form-label">Email</label>
              <input type="email" id="email" name="email" class="form-input" placeholder="your@email.com" required autocomplete="email" />
            </div>

            <div class="form-group">
              <label for="message" class="form-label">Message</label>
              <textarea id="message" name="message" class="form-input form-textarea" placeholder="Tell me about your project..." rows="5" required></textarea>
            </div>

            <Button class="contact__submit">Send message</Button>
          </form>
        </Card>
      </TwoCol>
    </Section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .hero {
    min-height: 100vh;
    display: grid;
    align-items: center;
    padding-top: calc(var(--header-height) + var(--space-md));
    overflow: clip;
  }

  .hero__content {
    position: relative;
    z-index: 1;
  }

  .hero__eyebrow {
    font-family: var(--text-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero__headline {
    max-width: 10ch;
  }

  .hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-text-soft);
  }

  .hero__meta span {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.85rem;
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--color-panel) 90%, transparent);
    border: 1px solid var(--color-border);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .hero__visual {
    position: relative;
    min-height: 32rem;
    display: grid;
    place-items: center;
  }

  .hero__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
    opacity: 0.22;
    pointer-events: none;
    animation: float 7s var(--ease-standard) infinite;
  }

  .hero__orb--primary {
    width: 18rem;
    height: 18rem;
    top: 0;
    right: 0;
    background: rgba(163, 230, 53, 0.45);
  }

  .hero__orb--secondary {
    width: 14rem;
    height: 14rem;
    bottom: 2rem;
    left: 0;
    background: rgba(20, 112, 110, 0.35);
    animation-delay: 1s;
  }

  .hero__panel {
    position: relative;
    width: min(100%, 31rem);
    padding: var(--space-lg);
    z-index: 1;
  }

  .hero__panel-bar {
    display: flex;
    gap: 0.45rem;
    margin-bottom: var(--space-lg);
  }

  .hero__panel-bar span {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    background: var(--color-border-strong);
  }

  .hero__panel-bar span:nth-child(1) {
    background: #ff5f57;
  }

  .hero__panel-bar span:nth-child(2) {
    background: #febc2e;
  }

  .hero__panel-bar span:nth-child(3) {
    background: #28c840;
  }

  .hero__code {
    margin: 0;
    width: 100%;
    overflow-x: auto;
    font-size: var(--text-sm);
    line-height: 1.9;
    color: var(--color-text-soft);
  }

  .hero__token-keyword {
    color: var(--color-brand-soft);
  }

  .hero__token-name {
    color: var(--color-text);
  }

  .hero__token-key {
    color: var(--color-accent);
  }

  .hero__token-string {
    color: var(--color-brand-soft);
  }

  .hero__note {
    position: absolute;
    right: 0;
    bottom: 1.5rem;
    width: min(15rem, 45%);
    padding: var(--space-md);
    z-index: 2;
  }

  .hero__note-label {
    margin-bottom: 0.35rem;
    font-size: var(--text-xs);
    font-family: var(--text-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .hero__note-value {
    color: var(--color-text);
    font-weight: var(--weight-semibold);
  }

  .hero__scroll {
    position: absolute;
    bottom: var(--space-lg);
    left: 50%;
    transform: translateX(-50%);
  }

  .hero__scroll span {
    display: block;
    width: 1px;
    height: 3rem;
    background: linear-gradient(to bottom, var(--color-accent), transparent);
    transform-origin: top;
    animation: pulse-line 2s var(--ease-standard) infinite;
  }

  .about__stats {
    margin-top: var(--space-3xl);
  }

  .about__card {
    min-height: 100%;
    padding: var(--space-lg);
  }

  .about__value {
    display: block;
    margin-bottom: var(--space-xs);
    font-size: var(--text-4xl);
    font-weight: var(--weight-black);
    color: var(--color-accent);
    letter-spacing: -0.05em;
  }

  .about__label {
    color: var(--color-text-soft);
  }

  .skill-card {
    padding: var(--space-xl);
  }

  .skill-card__glyph {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    margin-bottom: var(--space-md);
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, color-mix(in srgb, var(--color-brand) 90%, white 10%), var(--color-brand-soft));
    color: white;
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    letter-spacing: 0.08em;
  }

  .skill-card__title {
    margin-bottom: var(--space-md);
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
  }

  .skill-card__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .skill-card__item {
    position: relative;
    padding-left: var(--space-md);
    font-size: var(--text-sm);
    color: var(--color-text-soft);
  }

  .skill-card__item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    transform: translateY(-50%);
    background: var(--color-accent);
  }

  .experience__timeline {
    max-width: 52rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .timeline-item {
    display: flex;
    gap: var(--space-lg);
    position: relative;
  }

  .timeline-item__rail {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    padding-top: 1.2rem;
  }

  .timeline-item__dot {
    width: 0.85rem;
    height: 0.85rem;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0 0.35rem color-mix(in srgb, var(--color-accent) 20%, transparent);
  }

  .timeline-item__line {
    width: 1px;
    flex: 1;
    margin-top: var(--space-xs);
    background: linear-gradient(to bottom, color-mix(in srgb, var(--color-accent) 35%, var(--color-border)), transparent);
  }

  .timeline-item__card {
    width: 100%;
    padding: var(--space-lg);
  }

  .timeline-item__period {
    font-family: var(--text-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent-strong);
  }

  .timeline-item__role {
    margin-top: var(--space-xs);
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
  }

  .timeline-item__company {
    margin-bottom: var(--space-sm);
    color: var(--color-text-soft);
  }

  .timeline-item__description {
    margin-bottom: var(--space-md);
    color: var(--color-text-soft);
  }

  .timeline-item__highlights {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .highlight-tag {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding-inline: 0.85rem;
    border-radius: var(--radius-full);
    border: 1px solid color-mix(in srgb, var(--color-accent) 26%, var(--color-border));
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    font-size: var(--text-xs);
    color: var(--color-accent-strong);
  }

  .project-card {
    overflow: hidden;
  }

  .project-card__preview {
    position: relative;
    aspect-ratio: 16 / 10.5;
    overflow: hidden;
    background: linear-gradient(135deg, var(--color-brand-deep), var(--color-brand-soft));
  }

  .project-card__glow {
    position: absolute;
    inset: auto auto -10% -5%;
    width: 14rem;
    height: 14rem;
    border-radius: 50%;
    background: rgba(163, 230, 53, 0.28);
    filter: blur(40px);
  }

  .project-card__preview-inner {
    position: relative;
    z-index: 1;
    display: flex;
    height: 100%;
    flex-direction: column;
    justify-content: flex-end;
    gap: var(--space-sm);
    padding: var(--space-lg);
  }

  .project-card__index {
    font-size: clamp(3rem, 7vw, 5rem);
    line-height: 1;
    font-weight: var(--weight-black);
    color: rgba(255, 255, 255, 0.9);
  }

  .project-card__preview-label {
    font-family: var(--text-mono);
    font-size: var(--text-sm);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
  }

  .project-card__body {
    padding: var(--space-lg);
  }

  .project-card__title {
    margin-bottom: var(--space-sm);
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
  }

  .project-card__description {
    margin-bottom: var(--space-md);
    color: var(--color-text-soft);
  }

  .project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-sm);
  }

  .project-tag {
    display: inline-flex;
    align-items: center;
    min-height: 1.9rem;
    padding-inline: 0.75rem;
    border-radius: var(--radius-full);
    background: var(--color-panel-inset);
    border: 1px solid var(--color-border);
    font-size: var(--text-xs);
    color: var(--color-text-soft);
  }

  .contact__info,
  .contact__form-card {
    padding: var(--space-xl);
  }

  .contact__info-title {
    margin-bottom: var(--space-md);
    font-size: var(--text-xl);
  }

  .contact__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    min-height: 3rem;
    padding-inline: 1rem;
    border-radius: var(--radius-md);
    background: var(--color-panel-inset);
    border: 1px solid var(--color-border);
    color: var(--color-text-soft);
    transition:
      color var(--duration-fast) var(--ease-standard),
      transform var(--duration-fast) var(--ease-standard),
      border-color var(--duration-fast) var(--ease-standard);
  }

  .contact-link:hover {
    color: var(--color-accent);
